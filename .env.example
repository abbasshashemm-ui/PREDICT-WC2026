# Supabase — copy to .env.local and fill from:
# https://supabase.com/dashboard/project/zseynrxkhsquqvaxmlpl/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Official results table (public read via RLS)
# VITE_SUPABASE_RESULTS_TABLE=match_results

# Client live feed — defaults to /api/live-results when deployed on Vercel
# VITE_LIVE_RESULTS_API_URL=/api/live-results

# Server-only (Vercel project env — never expose to client)
# API_FOOTBALL_KEY=your-api-sports-key
# API_FOOTBALL_LEAGUE_ID=1
# API_FOOTBALL_SEASON=2026
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# CRON_SECRET=random-secret-for-sync-endpoint
# ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard
